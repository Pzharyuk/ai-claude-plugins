{
  "mcpServers": {
    "unifi-network": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/index.js"],
      "env": {
        "UNIFI_HOST": "${UNIFI_HOST}",
        "UNIFI_USERNAME": "${UNIFI_USERNAME}",
        "UNIFI_PASSWORD": "${UNIFI_PASSWORD}",
        "UNIFI_SITE": "${UNIFI_SITE}",
        "UNIFI_VERIFY_SSL": "${UNIFI_VERIFY_SSL}"
      }
    }
  }
}
